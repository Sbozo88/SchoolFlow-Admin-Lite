{
  "name": "schoolflow-admin-lite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "tsx --tsconfig tsconfig.json --test src/lib/saas.test.ts && npm --prefix functions test",
    "test:rules": "PATH=/opt/homebrew/opt/openjdk/bin:$PATH npx --yes firebase-tools@15 emulators:exec --only firestore --project schoolflow-admin-lite-rules-test \"tsx --tsconfig tsconfig.json --test tests/firestore.rules.test.ts\"",
    "lint:functions": "npm --prefix functions run lint",
    "test:e2e": "playwright test",
    "bootstrap:demo": "tsx --tsconfig tsconfig.json scripts/bootstrap-demo-platform.mjs",
    "deploy": "npm run build && firebase deploy --project schoolflow-admin-lite --non-interactive --force",
    "deploy:hosting": "npm run build && firebase deploy --only hosting --project schoolflow-admin-lite --non-interactive --force",
    "sync": "bash scripts/auto-commit-push.sh",
    "auto:commit": "bash scripts/auto-commit-push.sh",
    "auto:push": "bash scripts/auto-commit-push.sh"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "lucide-react": "^1.17.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.8.1"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "protobufjs": "^8.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  }
}
