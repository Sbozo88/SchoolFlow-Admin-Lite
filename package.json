{
  "name": "schoolflow-admin-lite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --tsconfig tsconfig.json --test src/lib/saas.test.ts",
    "deploy": "npm run build && firebase deploy --project schoolflow-admin-lite --non-interactive",
    "deploy:hosting": "npm run build && firebase deploy --only hosting --project schoolflow-admin-lite --non-interactive",
    "sync": "bash scripts/auto-commit-push.sh",
    "auto:commit": "bash scripts/auto-commit-push.sh",
    "auto:push": "bash scripts/auto-commit-push.sh"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "lucide-react": "^1.17.0",
    "next": "^15.5.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "protobufjs": "^8.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
