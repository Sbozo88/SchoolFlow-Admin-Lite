<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" role="img" aria-label="SchoolFlow Admin LITE">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0f172a" />
      <stop offset="100%" stop-color="#1e293b" />
    </linearGradient>
    <linearGradient id="cap-top" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#fb923c" />
      <stop offset="100%" stop-color="#f97316" />
    </linearGradient>
  </defs>
  <rect width="64" height="64" rx="16" fill="url(#bg)" />
  
  <!-- Head & Shoulders Silhouette -->
  <path d="M18 53c0-5 6-7 14-7s14 2 14 7" fill="none" stroke="#e2e8f0" stroke-width="3.5" stroke-linecap="round" />
  <circle cx="32" cy="38" r="7.5" fill="#ffffff" />
  
  <!-- Graduation Cap -->
  <!-- Cap Skull/Base -->
  <path d="M23 27c0 3 4 5 9 5s9-2 9-5" fill="none" stroke="#ffffff" stroke-width="3.5" stroke-linecap="round" />
  
  <!-- Cap Diamond Top -->
  <polygon points="32,11 49,19 32,27 15,19" fill="url(#cap-top)" stroke="#ffffff" stroke-width="1.5" stroke-linejoin="round" />
  
  <!-- Tassel -->
  <path d="M32 19 L45 23 V31" fill="none" stroke="#14b8a6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
  <circle cx="45" cy="33" r="2.5" fill="#fb923c" />
</svg>
